<section>
    <div class="container">
      <div class="best-sellers-wrap">
        <div class="best-sellers-collections">
          <div class="best-sellers-collections-label">{{ section.settings.section_label | default: "Best sellers" }}</div>
          <h2 class="best-sellers-collections-title">{{ section.settings.section_title | default: "Trending Products" }}</h2>
          <div class="best-sellers-collections-list">
            <ul>
              {% for block in section.blocks %}
                {% assign collection = collections[block.settings.collection] %}
                <li class="{% if forloop.first %}active{% endif %}" data-collection-index="{{ forloop.index0 }}">
                  {% if block.settings.collection_title != blank %}
                    {{ block.settings.collection_title }}
                  {% else %}
                    {{ collection.title }}
                  {% endif %}
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M14.43 5.92999L20.5 12L14.43 18.07" stroke="currentColor" stroke-width="1.5" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M3.5 12H20.33" stroke="currentColor" stroke-width="1.5" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </li>
              {% endfor %}
            </ul>
          </div>
        </div>
        {% for block in section.blocks %}
        {% assign collection = collections[block.settings.collection] %}
        {% if block.settings.product != blank %}
          {% assign product = block.settings.product %}
        {% else %}
          {% assign product = collection.products.first %}
        {% endif %}

        <div class="best-sellers-product {% if forloop.first %}active{% endif %}" data-collection-index="{{ forloop.index0 }}">
          <div class="best-sellers-product-wrap">

            {% if product.featured_media %}
              <a href="{{ product.url }}">
              <picture>
                <source media="(max-width: 767px)"
                        srcset="{{ product.featured_media | image_url: width: 400 }} 1x, {{ product.featured_media | image_url: width: 800 }} 2x">
                <source media="(min-width: 768px)"
                        srcset="{{ product.featured_media | image_url: width: 600 }} 1x, {{ product.featured_media | image_url: width: 1200 }} 2x">
                <img src="{{ product.featured_media | image_url: width: 600 }}"
                    alt="{{ product.featured_media.alt | escape }}"
                    width="600"
                    height="{{ 600 | divided_by: product.featured_media.aspect_ratio }}"
                    loading="lazy">
              </picture>
              </a>
            {% else %}
              <a href="{{ product.url }}"> {{ 'lifestyle-1' | placeholder_svg_tag: 'best-sellers-placeholder-img' }}</a>
            {% endif %}

            <div class="best-sellers-product-tags">
              <ul>
                {% for tag in product.tags limit: 3 %}
                  {% assign tag_lower = tag | downcase %}
                  <li class="best-sellers-product-tag {% if tag_lower == 'sale' %}sale{% endif %}">{{ tag }}</li>
                {% endfor %}
              </ul>
            </div>

            <div class="best-sellers-product-buttons">
              <button class="best-sellers-wishlist-button" data-product-id="{{ product.id }}" data-product-title="{{ product.title | escape }}">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M20.84 4.61012C20.3292 4.09912 19.7228 3.69376 19.0554 3.4172C18.3879 3.14064 17.6725 2.99829 16.95 2.99829C16.2275 2.99829 15.5121 3.14064 14.8446 3.4172C14.1772 3.69376 13.5708 4.09912 13.06 4.61012L12 5.67012L10.94 4.61012C9.90831 3.57842 8.50903 2.99883 7.05 2.99883C5.59096 2.99883 4.19169 3.57842 3.16 4.61012C2.1283 5.64181 1.54871 7.04108 1.54871 8.50012C1.54871 9.95915 2.1283 11.3584 3.16 12.3901L4.22 13.4501L12 21.2301L19.78 13.4501L20.84 12.3901C21.351 11.8794 21.7564 11.2729 22.0329 10.6055C22.3095 9.93801 22.4518 9.2226 22.4518 8.50012C22.4518 7.77763 22.3095 7.06222 22.0329 6.39476C21.7564 5.7273 21.351 5.12087 20.84 4.61012V4.61012Z" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              {% assign variant = product.selected_or_first_available_variant %}
              <button class="best-sellers-addtocart-button"
                      data-variant-id="{{ variant.id }}" data-product-title="{{ product.title | escape }}"
                      {% unless product.available %}disabled{% endunless %}>
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M15.58 11.9999C15.58 13.9799 13.98 15.5799 12 15.5799C10.02 15.5799 8.42001 13.9799 8.42001 11.9999C8.42001 10.0199 10.02 8.41992 12 8.41992C13.98 8.41992 15.58 10.0199 15.58 11.9999Z" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M12 20.27C15.53 20.27 18.82 18.19 21.11 14.59C22.01 13.18 22.01 10.81 21.11 9.39997C18.82 5.79997 15.53 3.71997 12 3.71997C8.47 3.71997 5.18 5.79997 2.89 9.39997C1.99 10.81 1.99 13.18 2.89 14.59C5.18 18.19 8.47 20.27 12 20.27Z" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </div>

            <div class="best-sellers-product-info">
              <div class="best-sellers-product-title">
                <a href="{{ product.url }}">
                  <h3>{{ product.title }}</h3>
                </a>
              </div>
              <div class="best-sellers-product-price">
                {% if product.compare_at_price > product.price %}
                  <span class="best-sellers-product-current-price">{{ product.price | money }}</span>
                  <span class="best-sellers-product-original-price">{{ product.compare_at_price | money }}</span>
                {% else %}
                  <span class="best-sellers-product-price">{{ product.price | money }}</span>
                {% endif %}
              </div>
            </div>

          </div>
        </div>
      {% endfor %}
      </div>
    </div>
    <div class="best-sellers-favorite-popup">
      <div class="best-sellers-popup-product-close">
        &times;
      </div>
      <div class="best-sellers-popup-product-title">
        <h3 class="best-sellers-popup-product-name"></h3>
      </div>
      <div class="best-sellers-popup-product-note">
        has been added to your wishlist
      </div>
    </div>
    <div class="best-sellers-addtocart-popup">
      <div class="best-sellers-popup-addtocart-close">
        &times;
      </div>
      <div class="best-sellers-popup-addtocart-title">
        <h3 class="best-sellers-popup-addtocart-name"></h3>
      </div>
      <div class="best-sellers-popup-addtocart-note">
        has been added to cart
      </div>
      <div class="best-sellers-popup-addtocart-buttons">
        <a href="{{ routes.cart_url }}" class="black-button">Cart</a>
        <a href="#" class="outline-button">Close</a>
      </div>
    </div>
</section>

{% schema %}
{
  "name": "Best sellers",
  "settings": [
    {
      "type": "text",
      "id": "section_label",
      "label": "Section label",
      "default": "Section label"
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Section title",
      "default": "Section title"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "limit": 3,
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "collection_title",
          "label": "Collection title"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Best sellers",
      "blocks": [
        {
          "type": "collection"
        }
      ]
    }
  ]
}
{% endschema %}