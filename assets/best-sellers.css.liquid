.best-sellers-wrap {
  padding-top: 32px;
  padding-bottom: 32px;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  margin-left: -8px;
  margin-right: -8px;
}

.best-sellers-collections {
  width: 100%;
  padding-left: 8px;
  padding-right: 8px;
  margin-bottom: 24px;
}

.best-sellers-collections-label {
  font-size: 16px;
  line-height: 24px;
  color: #535353;
}

.best-sellers-collections-title {
  font-size: 28px;
  line-height: 34px;
  font-weight: 500;
  margin: 0 0 24px;
}

.best-sellers-collections-list ul{
  list-style: none;
  padding: 0;
  margin: 0;
}

.best-sellers-collections-list ul li {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap:8px;
  height: 76px;
  border-bottom: 1px solid #DCDCDC;
  padding-left: 24px;
  padding-right: 24px;
  cursor: pointer;
  color: #DCDCDC;
  transition: color 0.3s ease;
  font-size: 22px;
  line-height: 28px;
  font-weight: 500;
}

.best-sellers-collections-list ul li svg{
  flex-shrink:0;
}

.best-sellers-collections-list ul li:hover {
  color: #000000;
}

.best-sellers-collections-list ul li.active {
  color: #000000;
}

.best-sellers-product{
  display: none;
  width: 100%;
  padding-left: 8px;
  padding-right: 8px;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.best-sellers-product.active{
  display: block;
}

.best-sellers-product.active.show {
  opacity: 1;
}

.best-sellers-product-wrap{
  position: relative;
  aspect-ratio: 1 / 1;
}

.best-sellers-product img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 16px;
}

.best-sellers-placeholder-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.best-sellers-product-tags{
  position: absolute;
  top: 8px;
  left: 8px;
}

.best-sellers-product-tags ul{
  list-style: none;
  padding: 0;
  margin: 0;
}

.best-sellers-product-tags ul li{
  font-size: 14px;
  line-height: 18px;
  font-weight: 500;
  text-transform: capitalize;
  padding: 8px 16px;
  margin-bottom: 4px;
  background-color: #fff;
  border-radius: 8px;
}

.best-sellers-product-tags ul li.sale{
  color: #fff;
  background-color: #E41616;
}

.best-sellers-product-buttons{
  position: absolute;
  top: 8px;
  right: 8px;
}

.best-sellers-product-buttons button{
  width: 40px;
  height: 40px;
  border: 1px solid #DCDCDC;
  background-color: #fff;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 4px;
  cursor: pointer;
  transition: all 0.3s ease;
}

.best-sellers-product-buttons button:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.15);
}

.best-sellers-addtocart-button:disabled {
  cursor: not-allowed;
  opacity: 0.4;
}

.best-sellers-product-info{
  position: absolute;
  bottom: 8px;
  left: 8px;
  right: 8px;
  background-color: #fff;
  padding: 12px 16px;
  display: flex;
  flex-direction: column;
  border-radius: 16px;
}

.best-sellers-product-info a{
  color: #000000;
  text-decoration: none;
}

.best-sellers-product-title h3{
  font-size: 16px;
  line-height: 24px;
  font-weight: 500;
  margin: 0 0 4px;
}

.best-sellers-product-price{
  font-size: 16px;
  line-height: 24px;
  color: #000000;
  margin: 0;
}

.best-sellers-product-price .best-sellers-product-current-price{
  color: #E41616;
}

.best-sellers-product-price .best-sellers-product-original-price{
  color: #9D9D9D;
  text-decoration: line-through;
}

.best-sellers-wishlist-button.active svg path{
  fill:#E41616;
}

.best-sellers-favorite-popup{
  display: none;
  width: 450px;
  max-width: 95%;
  background-color: #fff;
  border-radius: 16px;
  position: fixed;
  padding: 32px 16px;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 999;
}

.best-sellers-favorite-popup.active{
  display: block;
}

.best-sellers-favorite-popup .best-sellers-popup-product-title h3{
  font-size: 16px;
  line-height: 24px;
  font-weight: 500;
  margin: 0 0 4px;
  text-align: center;
}

.best-sellers-favorite-popup .best-sellers-popup-product-note{
  text-align: center;
}

.best-sellers-favorite-popup .best-sellers-popup-product-close{
  position: absolute;
  top: 8px;
  right: 8px;
  width: 28px;
  height: 28px;
  line-height: 1;
  font-size: 24px;
  border: 1px solid #000;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  cursor: pointer;
}

.best-sellers-addtocart-popup{
  display: none;
  width: 450px;
  max-width: 95%;
  background-color: #fff;
  border-radius: 16px;
  position: fixed;
  padding: 32px 16px;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 999;
}

.best-sellers-addtocart-popup.active{
  display: block;
}

.best-sellers-addtocart-popup .best-sellers-popup-addtocart-title h3{
  font-size: 16px;
  line-height: 24px;
  font-weight: 500;
  margin: 0 0 4px;
  text-align: center;
}

.best-sellers-addtocart-popup .best-sellers-popup-addtocart-note{
  text-align: center;
  margin-bottom: 8px;
}

.best-sellers-addtocart-popup .best-sellers-popup-addtocart-buttons{
  display: flex;
  justify-content: center;
  gap:8px;
}

.best-sellers-addtocart-popup .black-button{
  width: 150px;
  max-width:100%;
  background-color: #000;
  border:1px solid #000;
  color:#fff;
  font-size: 16px;
  font-weight: 500;
  transition: all 0.3s ease;
  text-align:center;
  padding: 10px 15px;
  border-radius:8px;
}

.best-sellers-addtocart-popup .black-button:hover{
  opacity: 0.75;
}

.best-sellers-addtocart-popup .outline-button{
  width: 150px;
  max-width:100%;
  background-color: transparent;
  border:1px solid #000;
  color:#000;
  font-size: 16px;
  font-weight: 500;
  transition: all 0.3s ease;
  text-align:center;
  padding: 10px 15px;
  border-radius:8px;
}

.best-sellers-addtocart-popup .outline-button:hover{
  background-color: #000;
  color:#fff;
}

.best-sellers-addtocart-popup .best-sellers-popup-addtocart-close{
  position: absolute;
  top: 8px;
  right: 8px;
  width: 28px;
  height: 28px;
  line-height: 1;
  font-size: 24px;
  border: 1px solid #000;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  cursor: pointer;
}

@media (min-width: 992px) {
  .container {
    padding-left: 16px;
    padding-right: 16px;
  }
  .best-sellers-collections-title {
    font-size: 38px;
    line-height: 46px;
    margin: 0 0 64px;
  }
  .best-sellers-collections{
    width: 50%;
    padding-left: 72px;
    padding-right: 72px;
  }
  .best-sellers-product{
    width: 50%;
  }
  .best-sellers-product-tags{
    top: 16px;
    left: 16px;
  }
  .best-sellers-product-buttons{
    top: 16px;
    right: 16px;
  }
  .best-sellers-product-info{
    bottom: 16px;
    left: 16px;
    right: 16px;
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
  }
  .best-sellers-product-title{
    flex: 1;
    width: auto;
    min-width: 0;
  }

  .best-sellers-product-title h3{
    margin-bottom: 0; 
  }

  .best-sellers-product-price{
    flex-shrink: 0;
    white-space: nowrap;
    width: auto;
  }
  .best-sellers-collections-list ul li {
    font-size: 28px;
    line-height: 34px;
  }
}